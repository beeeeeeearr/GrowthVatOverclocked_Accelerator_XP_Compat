    <xpath>Defs/ThingDef[defName="kathanon_GrowthAccelerator_GrowthVatAccelerator"]/placeWorkers</xpath>
    <value>
      <li>GrowthVatAcceleratorXPCompat.PlaceWorker_ShowAcceleratorFacing</li>
    </value>
  </Operation>
</Patch>
